class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        numSet = set(nums)
        longest = 0

        for num in numSet:
            if (num - 1) not in numSet:  # start of sequence
                length = 1
                while (num + length) in numSet:  # keep counting
                    length += 1
                longest = max(longest, length)  # update longest

        return longest

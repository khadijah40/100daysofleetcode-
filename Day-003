class Solution:

    def encode(self, strs: List[str]) -> str:
       result = ""
       for word in strs:
         result += str(len(word)) + "#" + word
       return result 

    def decode(self, s: str) -> List[str]:
      i = 0
      result = []
      while i < len(s):
        j = s.index("#", i)
        length = int(s[i:j])
        word = s[j+1:j+1+length]
        result.append(word)
        i = j+1+length
      return result


